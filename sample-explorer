function drawGraph(d,name){
  var c=document.getElementById('gc'),ctx=c.getContext('2d');
  var W=c.offsetWidth,H=220;
  c.width=W*(devicePixelRatio||1);c.height=H*(devicePixelRatio||1);
  ctx.scale(devicePixelRatio||1,devicePixelRatio||1);ctx.clearRect(0,0,W,H);
  var cx=W/2,cy=H/2;
  (d.matches||[]).forEach(function(m,i){
    var a=(i/d.matches.length)*Math.PI*2-Math.PI/2,x=cx+Math.cos(a)*82,y=cy+Math.sin(a)*76;
    var col=m.type==='original'?'#4dc8f0':'#f04d8a';
    ctx.beginPath();ctx.moveTo(cx,cy);ctx.lineTo(x,y);ctx.strokeStyle=col+'44';ctx.lineWidth=1.5;ctx.stroke();
    ctx.beginPath();ctx.arc(x,y,14,0,6.28);ctx.fillStyle=col+'22';ctx.fill();ctx.strokeStyle=col;ctx.lineWidth=1.5;ctx.stroke();
    ctx.fillStyle=col;ctx.font='500 8px Space Mono,monospace';ctx.textAlign='center';ctx.textBaseline='middle';
    ctx.fillText(m.artist.split(' ').pop().slice(0,7),x,y);
  });
  ctx.beginPath();ctx.arc(cx,cy,22,0,6.28);ctx.fillStyle='rgba(200,240,77,.15)';ctx.fill();ctx.strokeStyle='#c8f04d';ctx.lineWidth=2;ctx.stroke();
  ctx.fillStyle='#c8f04d';ctx.font='700 8px Space Mono,monospace';ctx.textAlign='center';ctx.textBaseline='middle';
  ctx.fillText(name.slice(0,8),cx,cy);
  var nl=document.getElementById('nl');
  nl.innerHTML='<div class="ni"><div class="nd" style="background:var(--a)"></div><div class="ntl">'+name+'</div><div class="ny">YOUR TRACK</div></div>';
  (d.matches||[]).forEach(function(m){
    var col=m.type==='original'?'var(--a3)':'var(--a2)',lbl=m.type==='original'?'SOURCE':m.type==='flip'?'FLIP':'SIBLING';
    nl.innerHTML+='<div class="ni"><div class="nd" style="background:'+col+'"></div><div class="ntl">'+m.title+' \u2014 '+m.artist+'</div><div class="ny">'+m.year+' \u00b7 '+lbl+'</div></div>';
  });
}

