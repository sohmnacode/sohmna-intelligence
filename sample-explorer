  tp.innerHTML='<span class="aib">SOHMNA AI</span><span class="spin"></span>';
  m.appendChild(tp);m.scrollTop=m.scrollHeight;
  var sys='You are SOHMNA AI, an expert music historian and sample archaeologist with encyclopedic knowledge of sample-based music across hip-hop, funk, soul, jazz, reggae, and electronic music. Give specific artist names, years, record labels, and album names. Keep responses under 130 words. Bold key song names and artists with **text**.'+(_dna?' Context \u2014 analyzed track: BPM '+_dna.bpm+', Key '+_dna.key+', Era '+_dna.era+', Genres: '+(_dna.genre_tags||[]).join(', ')+'.':'');
  apiCall({system:sys,messages:_hist},function(err,data){
    var el=document.getElementById(tid);if(el)el.remove();
    var r=err?'Error: '+err.message:data.content.map(function(b){return b.text||'';}).join('');
    if(!err)_hist.push({role:'assistant',content:r});
    addMsg(r,'a');_lock=false;document.getElementById('csend').disabled=false;
  });
}

function addMsg(text,role){
  var m=document.getElementById('msgs');
  if(role==='u'){
    var w=document.createElement('div');w.style.cssText='display:flex;justify-content:flex-end';
    var b=document.createElement('div');b.className='mu';b.textContent=text;w.appendChild(b);m.appendChild(w);
  }else{
    var d=document.createElement('div');d.className='mai';
    d.innerHTML='<span class="aib">SOHMNA AI</span>'+text.replace(/\*\*(.+?)\*\*/g,'<strong>$1</strong>');
    m.appendChild(d);
  }
  m.scrollTop=m.scrollHeight;
}

function useSug(el){document.getElementById('ci').value=el.textContent;sendChat();}

function toast(msg){
  var t=document.getElementById('toast');t.textContent=msg;t.classList.add('show');
  setTimeout(function(){t.classList.remove('show');},2800);
}
</script>
